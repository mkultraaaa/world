{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "handle": "filesystem" },
    { "src": "/neurogate/campaign$", "dest": "/neurogate/campaign/index.html" },
    { "src": "/neurogate/business$", "dest": "/neurogate/business/index.html" },
    { "src": "/neurogate/examples$", "dest": "/neurogate/examples/index.html" },
    { "src": "/neurogate/invite$", "dest": "/neurogate/invite/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
